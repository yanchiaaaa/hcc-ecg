        "ablation_mode": "icd_tabular",
        "use_ema": true,
        "ema_decay": 0.9999,
        "ema_update_after": 6000,
        "ema_update_every": 1,
        "save_interval": 10,
        "resume": false,
        "resume_checkpoint_dir": ""
    }
